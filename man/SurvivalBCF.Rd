status <- rbinom(n, 1, 0.7)

fit <- SurvivalBCF(time = time, status = status, X_train = X,
                   treatment = treatment,
                   number_of_trees_control = 5,
                   number_of_trees_treat = 5,
                   N_post = 50, N_burn = 25,
                   verbose = FALSE)

