packageVersion("stringi"); packageVersion("stringr")
# 2. Replace check_spelling in the namespace with a fixed copy
fixed <- rjtools:::check_spelling
# Walk the body and rewrite the two regex strings in-place
swap <- function(expr) {
if (is.call(expr) || is.pairlist(expr)) {
for (i in seq_along(expr)) expr[[i]] <- swap(expr[[i]])
} else if (is.character(expr) && length(expr) == 1) {
if (identical(expr, "(?<=\\\\abstract\\{).*?"))
return("(?<=\\\\abstract\\{).*")
}
expr
}
body(fixed) <- swap(body(fixed))
assignInNamespace("check_spelling", fixed, ns = "rjtools")
rjtools::check_spelling(path = path, dic = "en_GB")
