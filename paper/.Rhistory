trace(rjtools:::check_spelling, edit = FALSE,
tracer = quote({
body(check_spelling)[[3]] <- quote(
detect_abstract <- purrr::map(tex, ~stringr::str_extract(.x,
"(?<=\\\\abstract\\{).*"))   # greedy, not lazy
)
}))
