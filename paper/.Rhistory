fixed_check_spelling <- function(path, dic = "en_US", ...) {
tex <- rjtools:::extract_tex_vec(path)
abs_loc <- grep("\\\\abstract\\{",     tex)[1]
bib_loc <- grep("\\\\bibliography\\{", tex)[1]
if (is.na(abs_loc) || is.na(bib_loc))
stop("Could not locate \\abstract{ or \\bibliography{ in ", path)
to_replace <- paste(rjtools:::spell_to_remove, collapse = "|")
tex2  <- stringr::str_replace_all(tex, to_replace, "")
body  <- tex2[(abs_loc + 1):(bib_loc - 1)]
cb <- which(body == "\\begin{Schunk}")
ce <- which(body == "\\end{Schunk}")
if (length(cb)) body <- body[-unlist(Map(`:`, cb, ce))]
hits <- unique(unlist(hunspell::hunspell(
body, format = "latex",
dict = hunspell::dictionary(dic), ...
)))
hits <- hits[tolower(hits) == hits]   # ignore acronyms / proper nouns
if (length(hits)) {
cat("NOTE: A potential list of spelling to check:\n  ",
paste(hits, collapse = ", "), "\n")
} else {
cat("SUCCESS: No spelling mistake detected\n")
}
invisible(hits)
}
# Run it
candidates <- fixed_check_spelling(path = path, dic = "en_GB")
assignInNamespace("check_spelling", function(path, dic = "en_US", ...) {
fixed_check_spelling(path, dic, ...)
invisible(NULL)
}, ns = "rjtools")
rjtools::initial_check_article(path = path, dic = "en_GB")
