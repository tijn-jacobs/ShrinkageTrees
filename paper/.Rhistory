rjtools::check_spelling(path = path, dic = "en_GB")
untrace(rjtools:::check_spelling)   # clear the no-op trace
# Grab the original, patch the regex, reinstall it in the namespace
fixed <- rjtools:::check_spelling
body(fixed) <- body(fixed)   # ensure mutable copy
b <- body(fixed)
# Find and rewrite the abstract-detection line (it's the assignment to detect_abstract)
for (i in seq_along(b)) {
if (is.call(b[[i]]) && identical(b[[i]][[1]], as.name("<-")) &&
identical(b[[i]][[2]], as.name("detect_abstract"))) {
b[[i]] <- quote(
detect_abstract <- purrr::map(
tex, ~ stringr::str_extract(.x, "(?<=\\\\abstract\\{).*")
)
)
break
}
}
body(fixed) <- b
assignInNamespace("check_spelling", fixed, ns = "rjtools")
